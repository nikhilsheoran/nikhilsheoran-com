# ──────────────────────────────────────────
# Convex
# ──────────────────────────────────────────
# Auto-generated by `bunx convex dev`
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud
# Same URL but ending in .site (for auth proxying)
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment-name.convex.site

# ──────────────────────────────────────────
# Site URL (used by Better Auth)
# ──────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ──────────────────────────────────────────
# Better Auth (set via Convex CLI, NOT .env.local)
# Run: bunx convex env set BETTER_AUTH_SECRET=$(openssl rand -base64 32)
# ──────────────────────────────────────────
# BETTER_AUTH_SECRET=    ← set in Convex dashboard / CLI

# ──────────────────────────────────────────
# Google OAuth (set via Convex CLI, NOT .env.local)
# Run:
#   bunx convex env set GOOGLE_CLIENT_ID=your-client-id
#   bunx convex env set GOOGLE_CLIENT_SECRET=your-client-secret
# Also set in Convex:
#   bunx convex env set SITE_URL=https://nikhilsheoran.com
# ──────────────────────────────────────────
# GOOGLE_CLIENT_ID=REDACTED_GOOGLE_CLIENT_ID
# GOOGLE_CLIENT_SECRET=REDACTED_GOOGLE_CLIENT_SECRET

